<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BUILD YOUR PERFECT BODY - Posturacorretta</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="bg-gray-50 min-h-screen">
    <!-- Header -->
    <header class="bg-white shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <!-- Logo -->
          <div class="flex-shrink-0">
            <img src="/_next/static/assets/4yh1nD6lrZHSkS0DK7DPp/images/logos/logo-default-primary-soft.svg" alt="Posturacorretta" class="h-8">
          </div>
          <!-- Navigation -->
          <nav class="flex items-center space-x-8">
            <a href="/support-proxy" target="_blank" class="text-gray-600 hover:text-gray-900">Help</a>
            <select class="text-gray-600 border-none bg-transparent">
              <option>English</option>
            </select>
            <button class="md:hidden">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
            </button>
          </nav>
        </div>
      </div>
    </header>
    <!-- Main Content -->
    <main class="flex-1">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <!-- Hero Section -->
        <div class="text-center mb-12">
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
            BUILD YOUR PERFECT BODY
          </h1>
          <p class="text-xl text-gray-600 mb-8">
            According to your age and BMI
          </p>
        </div>
        <!-- Age Selection Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
          <!-- 18-29 Card -->
          <label class="relative cursor-pointer group">
            <input type="radio" name="ageDiapazone" value="18-29" class="sr-only">
            <div class="bg-white rounded-lg shadow-md p-6 transition-all group-hover:shadow-lg border-2 border-transparent group-hover:border-orange-500">
              <div class="flex flex-col items-center">
                <img src="https://s3.Posturacorretta.com/frontend/quizes_images/4d801b76-b167-44cc-a037-0d272ccbe068.png" 
                                 alt="I'm 18-29" class="w-24 h-24 object-cover rounded-lg mb-4">
                <div class="flex items-center justify-between w-full">
                  <p class="text-lg font-semibold text-gray-900">I'm 18-29</p>
                  <svg class="w-6 h-6 text-blue-500 fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                </div>
              </div>
            </div>
          </label>
          <!-- 30-39 Card -->
          <label class="relative cursor-pointer group">
            <input type="radio" name="ageDiapazone" value="30-39" class="sr-only">
            <div class="bg-white rounded-lg shadow-md p-6 transition-all group-hover:shadow-lg border-2 border-transparent group-hover:border-orange-500">
              <div class="flex flex-col items-center">
                <img src="https://s3.Posturacorretta.com/frontend/quizes_images/6224a002-7a91-4c4f-9ece-c6ebfbe0cbf1.png" 
                                 alt="I'm 30-39" class="w-24 h-24 object-cover rounded-lg mb-4">
                <div class="flex items-center justify-between w-full">
                  <p class="text-lg font-semibold text-gray-900">I'm 30-39</p>
                  <svg class="w-6 h-6 text-blue-500 fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                </div>
              </div>
            </div>
          </label>
          <!-- 40-49 Card -->
          <label class="relative cursor-pointer group">
            <input type="radio" name="ageDiapazone" value="40-49" class="sr-only">
            <div class="bg-white rounded-lg shadow-md p-6 transition-all group-hover:shadow-lg border-2 border-transparent group-hover:border-orange-500">
              <div class="flex flex-col items-center">
                <img src="https://s3.Posturacorretta.com/frontend/quizes_images/10e4c5c0-ec12-43f0-8b31-ef016fdc23ba.png" 
                                 alt="I'm 40-49" class="w-24 h-24 object-cover rounded-lg mb-4">
                <div class="flex items-center justify-between w-full">
                  <p class="text-lg font-semibold text-gray-900">I'm 40-49</p>
                  <svg class="w-6 h-6 text-blue-500 fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                </div>
              </div>
            </div>
          </label>
          <!-- 50+ Card -->
          <label class="relative cursor-pointer group">
            <input type="radio" name="ageDiapazone" value="50+" class="sr-only">
            <div class="bg-white rounded-lg shadow-md p-6 transition-all group-hover:shadow-lg border-2 border-transparent group-hover:border-orange-500">
              <div class="flex flex-col items-center">
                <img src="https://s3.Posturacorretta.com/frontend/quizes_images/ebac8704-00a6-461f-a7ba-17b82eb80396.png" 
                                 alt="I'm 50+" class="w-24 h-24 object-cover rounded-lg mb-4">
                <div class="flex items-center justify-between w-full">
                  <p class="text-lg font-semibold text-gray-900">I'm 50+</p>
                  <svg class="w-6 h-6 text-blue-500 fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                </div>
              </div>
            </div>
          </label>
        </div>
        <!-- Terms and Legal -->
        <div class="mb-8">
          <label class="flex items-start space-x-3 cursor-pointer">
            <input type="checkbox" checked class="mt-1 w-5 h-5 text-blue-500 border-gray-300 rounded focus:ring-orange-500">
            <span class="text-sm text-gray-600">
              By continuing, you agree to our 
              <a href="/terms-of-service" class="text-blue-500 hover:underline">Terms of service</a>
              and acknowledge our 
              <a href="/privacy-policy" class="text-blue-500 hover:underline">Privacy policy</a>
              and 
              <a href="/cookie-policy" class="text-blue-500 hover:underline">Cookie policy</a>
            </span>
          </label>
        </div>
        <!-- Medical Disclaimer -->
        <p class="text-center text-sm text-gray-500 mb-8">
          We recommend that you consult with your physician before beginning any exercise program
        </p>
        <!-- Continue Button -->
        <div class="text-center">
          <button class="w-full md:w-auto bg-orange-500 hover:bg-orange-600 text-white font-semibold py-4 px-8 rounded-lg transition-colors text-lg">
            Continue
          </button>
        </div>
      </div>
    </main>
    <!-- Mobile Navigation Menu (Hidden by default) -->
    <div class="fixed inset-0 z-50 hidden" id="mobile-menu">
      <div class="fixed inset-0 bg-black bg-opacity-50"></div>
      <div class="fixed top-0 right-0 w-64 h-full bg-white shadow-lg">
        <div class="flex items-center justify-between p-4 border-b">
          <span class="font-semibold">Menu</span>
          <button id="close-menu">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
        <nav class="p-4 space-y-4">
          <a href="#" class="block text-gray-600 hover:text-gray-900">Change Language</a>
          <a href="#" class="block text-gray-600 hover:text-gray-900">Terms & Policies</a>
          <a href="#" class="block text-gray-600 hover:text-gray-900">FAQ</a>
          <a href="#" class="block text-gray-600 hover:text-gray-900">My Account</a>
          <a href="#" class="block text-gray-600 hover:text-gray-900">Support</a>
        </nav>
      </div>
    </div>
    <script>
      // Simple JavaScript for mobile menu
      document.querySelector('button.md\\:hidden').addEventListener('click', function() {
          document.getElementById('mobile-menu').classList.remove('hidden');
      });

      document.getElementById('close-menu').addEventListener('click', function() {
          document.getElementById('mobile-menu').classList.add('hidden');
      });

      // Handle age selection
      document.querySelectorAll('input[name="ageDiapazone"]').forEach(input => {
          input.addEventListener('change', function() {
              document.querySelectorAll('label').forEach(label => {
                  label.querySelector('div').classList.remove('border-orange-500', 'shadow-lg');
                  label.querySelector('div').classList.add('border-transparent');
              });

              if (this.checked) {
                  const label = this.closest('label');
                  label.querySelector('div').classList.add('border-orange-500', 'shadow-lg');
                  label.querySelector('div').classList.remove('border-transparent');
              }
          });
      });
    </script>
  </body>
</html>
