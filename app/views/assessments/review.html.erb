<div class="max-w-5xl mx-auto">
  <!-- Progress Complete -->
  <div class="mb-8">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-lg font-semibold text-green-800">
        ✅ Test Completato!
      </h2>
      <span class="text-sm font-medium text-green-600">
        Tutti i 10 passi completati
      </span>
    </div>
    
    <div class="w-full bg-gray-200 rounded-full h-4 mb-4">
      <div class="bg-gradient-to-r from-green-500 to-emerald-600 h-4 rounded-full" style="width: 100%"></div>
    </div>
  </div>

  <!-- Review Content -->
  <div class="bg-white rounded-xl shadow-lg p-8">
    <div class="text-center mb-8">
      <div class="text-6xl mb-4">🎉</div>
      <h2 class="text-3xl font-bold text-gray-800 mb-4">Ottimo Lavoro!</h2>
      <p class="text-gray-600 text-lg">
        Hai completato tutti gli esercizi. Controlla i tuoi punteggi prima di vedere i risultati finali.
      </p>
    </div>

    <!-- Personal Info Summary -->
    <div class="bg-blue-50 border-2 border-blue-200 rounded-lg p-6 mb-8">
      <h3 class="text-xl font-bold text-blue-900 mb-4">👤 Riepilogo Dati</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="flex items-center space-x-2">
          <span class="font-semibold text-blue-800">Nome:</span>
          <span class="text-blue-700"><%= @assessment.name %></span>
        </div>
        <div class="flex items-center space-x-2">
          <span class="font-semibold text-blue-800">Età:</span>
          <span class="text-blue-700"><%= @assessment.age %> anni</span>
        </div>
        <div class="flex items-center space-x-2">
          <span class="font-semibold text-blue-800">📧 Email:</span>
          <span class="text-blue-700"><%= @assessment.email %></span>
        </div>
        <% if @assessment.phone_number.present? %>
          <div class="flex items-center space-x-2">
            <span class="font-semibold text-blue-800">📱 Telefono:</span>
            <span class="text-blue-700">
              <%= @assessment.country_flag %> <%= @assessment.full_phone_number %>
            </span>
          </div>
        <% end %>
      </div>
      <% if @assessment.notes.present? %>
        <div class="mt-4 pt-4 border-t border-blue-200">
          <span class="font-semibold text-blue-800">Note:</span>
          <p class="text-blue-700 mt-1"><%= simple_format(@assessment.notes) %></p>
        </div>
      <% end %>
    </div>

    <!-- Total Score Preview -->
    <div class="bg-gradient-to-br from-purple-50 to-blue-50 border-2 border-purple-200 rounded-lg p-8 mb-8">
      <div class="text-center">
        <h3 class="text-2xl font-bold text-gray-800 mb-4">🎯 Il Tuo Punteggio</h3>
        <div class="text-7xl font-bold text-purple-600 mb-4"><%= @assessment.total_score %></div>
        <div class="text-xl text-gray-600 mb-4">su 27 punti possibili</div>
        <div class="inline-flex items-center space-x-2 bg-white px-4 py-2 rounded-full border border-purple-200">
          <span class="text-purple-600 font-semibold">Percentuale:</span>
          <span class="text-purple-800 font-bold"><%= sprintf("%.1f", @assessment.total_score / 27.0 * 100) %>%</span>
        </div>
      </div>
    </div>

    <!-- Exercises Summary Grid -->
    <div class="mb-8">
      <h3 class="text-2xl font-bold text-gray-800 mb-6">📊 Riepilogo per Esercizio</h3>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <% Assessment::EXERCISES.each do |step_num, exercise| %>
          <% score = @assessment.send(exercise[:field]) %>
          <div class="border-2 border-gray-200 rounded-lg p-4 hover:shadow-md transition-shadow">
            <div class="flex justify-between items-start mb-3">
              <h4 class="font-semibold text-gray-800 text-sm leading-tight">
                <%= step_num - 1 %>. <%= exercise[:title] %>
              </h4>
              <div class="flex items-center space-x-1 ml-2">
                <span class="text-2xl font-bold <%= 
                  case score
                  when 3 then 'text-green-600'
                  when 2 then 'text-blue-600' 
                  when 1 then 'text-yellow-600'
                  when 0 then 'text-red-600'
                  end %>">
                  <%= score %>
                </span>
                <span class="text-gray-400 text-sm">/3</span>
              </div>
            </div>
            
            <p class="text-xs text-gray-600 mb-3"><%= exercise[:criteria][score] %></p>
            
            <!-- Progress bar for this exercise -->
            <div class="w-full bg-gray-200 rounded-full h-2">
              <div class="h-2 rounded-full <%= 
                case score
                when 3 then 'bg-green-500'
                when 2 then 'bg-blue-500'
                when 1 then 'bg-yellow-500' 
                when 0 then 'bg-red-500'
                end %>" 
                   style="width: <%= (score / 3.0 * 100).round %>%"></div>
            </div>
            
            <div class="mt-2 text-right">
              <span class="text-xs font-medium <%= 
                case score
                when 3 then 'text-green-600'
                when 2 then 'text-blue-600'
                when 1 then 'text-yellow-600'
                when 0 then 'text-red-600'
                end %>">
                <%= 
                  case score
                  when 3 then "Ottimo"
                  when 2 then "Buono"
                  when 1 then "Sufficiente"
                  when 0 then "Da migliorare"
                  end 
                %>
              </span>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Quick Stats -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-green-50 border border-green-200 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-green-600">
          <%= [@assessment.flexion_extension, @assessment.arms_overhead, @assessment.spine_rotation_right, @assessment.spine_rotation_left, @assessment.deep_squat, @assessment.hands_behind_back_right, @assessment.hands_behind_back_left, @assessment.straight_leg_raise_right, @assessment.straight_leg_raise_left].compact.count { |s| s == 3 } %>
        </div>
        <div class="text-sm text-green-800 font-medium">Punteggi Ottimi (3/3)</div>
      </div>
      
      <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-blue-600">
          <%= [@assessment.flexion_extension, @assessment.arms_overhead, @assessment.spine_rotation_right, @assessment.spine_rotation_left, @assessment.deep_squat, @assessment.hands_behind_back_right, @assessment.hands_behind_back_left, @assessment.straight_leg_raise_right, @assessment.straight_leg_raise_left].compact.count { |s| s == 2 } %>
        </div>
        <div class="text-sm text-blue-800 font-medium">Punteggi Buoni (2/3)</div>
      </div>
      
      <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-yellow-600">
          <%= [@assessment.flexion_extension, @assessment.arms_overhead, @assessment.spine_rotation_right, @assessment.spine_rotation_left, @assessment.deep_squat, @assessment.hands_behind_back_right, @assessment.hands_behind_back_left, @assessment.straight_leg_raise_right, @assessment.straight_leg_raise_left].compact.count { |s| s == 1 } %>
        </div>
        <div class="text-sm text-yellow-800 font-medium">Da Migliorare (1/3)</div>
      </div>
      
      <div class="bg-red-50 border border-red-200 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-red-600">
          <%= [@assessment.flexion_extension, @assessment.arms_overhead, @assessment.spine_rotation_right, @assessment.spine_rotation_left, @assessment.deep_squat, @assessment.hands_behind_back_right, @assessment.hands_behind_back_left, @assessment.straight_leg_raise_right, @assessment.straight_leg_raise_left].compact.count { |s| s == 0 } %>
        </div>
        <div class="text-sm text-red-800 font-medium">Limitati (0/3)</div>
      </div>
    </div>

    <!-- Final Action -->
    <div class="text-center">
      <%= form_with model: @assessment, url: assessments_path, local: true do |form| %>
        <%= form.submit "🎉 Visualizza Risultati Completi e Raccomandazioni", 
            class: "bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700 text-white font-bold py-4 px-8 rounded-xl text-lg transition-all duration-200 transform hover:scale-105 shadow-lg" %>
      <% end %>
    </div>

    <!-- Disclaimer -->
    <div class="mt-8 p-4 bg-yellow-50 border-l-4 border-yellow-400 rounded-lg">
      <div class="flex items-start">
        <div class="text-2xl mr-3">⚠️</div>
        <div>
          <p class="text-sm text-yellow-800">
            <strong>Nota importante:</strong> Questa valutazione ha scopo puramente informativo e non sostituisce 
            una consulenza medica professionale. Per problemi specifici, consulta un fisioterapista o medico specialista.
          </p>
        </div>
      </div>
    </div>
  </div>
</div>
